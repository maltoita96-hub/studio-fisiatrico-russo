---
import Icon from './Icon.astro';
interface Props {
  theme?: 'studio' | 'night';
}
const { theme = 'studio' } = Astro.props;
const night = theme === 'night';
/* Motion vive su una pagina separata: le ancore Studio vanno richiamate con "/" davanti. */
const home = night ? '/' : '';

const links = night
  ? [
      { href: '#programmi', label: 'Programmi' },
      { href: '#metodo', label: 'Metodo' },
      { href: '#coach', label: 'Coach' },
    ]
  : [
      { href: '#percorso', label: 'Percorso' },
      { href: '#trattamenti', label: 'Cosa trattiamo' },
      { href: '#medico', label: 'Il medico' },
      { href: '/motion/', label: 'Motion', wipe: true },
      { href: '#dove', label: 'Dove siamo' },
    ];
---
<nav class="nav" data-nav data-theme={night ? 'night' : undefined}>
  <div class="nav-utility hidden min-[900px]:block" data-theme={night ? 'night' : undefined}>
    <div class="wrap flex items-center justify-between gap-5">
      <a class="nav-util-link" href={`${home}#dove`}>
        <Icon name="mappin" size={13} /> Misterbianco, Catania
      </a>
      <div class="flex items-center gap-5">
        <a class="nav-util-link" href={`${home}#fiducia`}>
          <span class="flex items-center gap-0.5" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => <Icon name="star" size={11} />)}
          </span>
          5,0 <span class="hidden lg:inline">· 170+ recensioni</span>
        </a>
        <a class="nav-util-link" href="tel:+393421904804">
          <Icon name="phone" size={13} /> 342 190 4804
        </a>
        <a class="nav-util-link" href="https://www.instagram.com/toni__russo" target="_blank" rel="noopener" aria-label="Instagram">
          <Icon name="instagram" size={14} />
        </a>
      </div>
    </div>
  </div>
  <div class="wrap flex items-center justify-between gap-6 h-[68px]">
    {
      night ? (
        <a class="flex items-center gap-2.5 font-display font-semibold text-[1.08rem] text-night-ink whitespace-nowrap" href="/" data-wipe>
          Studio Fisiatrico Russo
          <span class="font-motion font-black text-[0.6rem] tracking-[0.14em] uppercase text-aqua-ink bg-aqua px-2 py-1 rounded shrink-0">Motion</span>
        </a>
      ) : (
        <a class="flex items-baseline gap-2 font-display font-semibold text-[1.14rem] text-ink whitespace-nowrap" href="/">
          Studio Fisiatrico Russo
          <span class="w-2 h-2 rounded-full bg-accent shrink-0 translate-y-[-2px]" aria-hidden="true"></span>
        </a>
      )
    }
    <div class:list={['nav-links flex items-center gap-7 text-body-sm font-medium', night ? 'text-night-ink/80' : 'text-muted']}>
      {links.map((l) => (
        <a href={l.href} data-wipe={'wipe' in l && l.wipe ? '' : undefined}>{l.label}</a>
      ))}
    </div>
    <div class="flex items-center gap-3.5">
      <a class:list={['btn max-[899px]:hidden', night ? 'btn-aqua' : 'btn-accent']} href="#prenota">
        Prenota <span class="arr" aria-hidden="true">→</span>
      </a>
      <button class="burger" id="burger" aria-label="Menu" aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-panel" id="mobileMenu" aria-hidden="true" data-theme={night ? 'night' : undefined}>
  {links.map((l) => (
    <a href={l.href} class="m-link" data-wipe={'wipe' in l && l.wipe ? '' : undefined}>{l.label}</a>
  ))}
  <a href="#faq" class="m-link">FAQ</a>
  <div class="mt-8 flex flex-col gap-3">
    <a class:list={['btn btn-lg', night ? 'btn-aqua' : 'btn-accent']} href="#prenota">Prenota la visita <span class="arr" aria-hidden="true">→</span></a>
    <a class:list={['btn btn-lg', night ? 'btn-ghost-night' : 'btn-outline']} href="tel:+393421904804">Chiama: 342 190 4804</a>
    {night && <a class="btn btn-lg btn-ghost-night" href="/" data-wipe>← Torna allo Studio</a>}
  </div>
</div>
