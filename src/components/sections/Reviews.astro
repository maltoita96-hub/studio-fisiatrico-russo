---
import Icon from '../Icon.astro';
/* Prova sociale conforme alla pubblicità sanitaria (L. 145/2018):
   niente testimonianze riportate sul sito — solo il dato aggregato, verificabile,
   con rimando alle piattaforme dove le recensioni sono pubbliche e non selezionabili. */
---
<section class="section bg-surface border-y border-line" id="fiducia">
  <div class="wrap grid gap-10 lg:grid-cols-[0.9fr_1.1fr] items-center">
    <div data-reveal="left">
      <span class="kicker-alt">Recensioni</span>
      <h2 class="h-display mt-3 max-w-[16ch]">La fiducia si verifica, non si dichiara.</h2>
    </div>
    <div data-reveal="right">
      <div class="flex items-baseline gap-4 flex-wrap">
        <span class="font-display font-semibold text-ink leading-none text-[clamp(3.2rem,6vw,4.6rem)]">5,0</span>
        <div>
          <span class="flex items-center gap-1 text-accent-ink" role="img" aria-label="5 stelle su 5">
            {Array.from({ length: 5 }).map(() => <Icon name="star" size={16} />)}
          </span>
          <p class="text-body-sm text-muted mt-1">media di oltre 170 recensioni pubbliche<br />105 su MioDottore · 69 su Google</p>
        </div>
      </div>
      <p class="mt-5 text-body-sm text-muted max-w-[52ch]">
        Le recensioni dei pazienti vivono sulle piattaforme, dove nessuno può selezionarle o
        riscriverle. Leggile lì, prima di prenotare: è il modo più onesto di scegliere un medico.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn btn-soft" href="https://g.co/kgs/RT4qEMv" target="_blank" rel="noopener">Leggile su Google <span class="arr" aria-hidden="true">→</span></a>
        <a class="btn btn-soft" href="https://www.miodottore.it/antonino-russo-4/fisiatra/catania#profile-reviews" target="_blank" rel="noopener">Leggile su MioDottore <span class="arr" aria-hidden="true">→</span></a>
      </div>
    </div>
  </div>
</section>
