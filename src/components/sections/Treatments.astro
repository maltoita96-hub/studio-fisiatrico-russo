---
import Icon from '../Icon.astro';
/* Zona anatomica, non elenco piatto: è come cercano i pazienti.
   Assorbe la ex sezione "Servizi": le procedure (ecografia, infiltrazioni,
   onde d'urto) sono già nelle checklist di Method qui accanto, ripeterle
   in una sezione a parte era pura ridondanza (4 zone, non 6+6 voci piatte). */
const aree = [
  { t: 'Colonna', d: 'Lombalgia (mal di schiena basso), cervicalgia, sciatalgia, ernia del disco, stenosi, colpo di frusta, cefalea di origine cervicale.' },
  { t: 'Spalla e gomito', d: 'Tendinopatia della cuffia dei rotatori, calcificazioni, spalla rigida, epicondilite (gomito del tennista).' },
  { t: 'Anca e ginocchio', d: 'Coxartrosi e gonartrosi (artrosi di anca e ginocchio), tendinopatia rotulea, borsiti, esiti di trauma e chirurgia.' },
  { t: 'Piede, caviglia e sport', d: 'Fascite plantare, distorsioni, infortuni muscolari e altri traumi sportivi.' },
];
---
<section class="section" id="trattamenti">
  <div class="wrap">
    <div class="flex flex-wrap items-end justify-between gap-6 mb-11">
      <div>
        <span class="eyebrow" data-reveal>Cosa trattiamo</span>
        <h2 class="h-display mt-3 max-w-[18ch]" data-reveal data-delay="80">Il dolore ha tante origini. Partiamo da dove fa male.</h2>
      </div>
      <p class="max-w-[34ch] text-muted" data-reveal data-delay="160">
        Le zone di cui ci occupiamo più spesso, sempre a partire da una valutazione: nessuna terapia “a catalogo”.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 gap-x-12" data-stagger="70">
      {aree.map((a) => (
        <div class="border-t border-line py-6 flex flex-col gap-1.5 transition-colors hover:border-t-accent" data-reveal>
          <h3 class="font-display text-[1.3rem] font-semibold">{a.t}</h3>
          <p class="text-[0.93rem] text-muted">{a.d}</p>
        </div>
      ))}
    </div>
    <p class="mt-8 text-[0.95rem] text-muted max-w-[60ch]" data-reveal>
      Ci occupiamo anche di riabilitazione post-chirurgica e, a distanza, di consulenza online e nutrizionale.
    </p>
    <p class="mt-3 flex flex-wrap items-center gap-2 text-[0.95rem] font-semibold" data-reveal>
      Non trovi il tuo problema?
      <a
        class="inline-flex items-center gap-1.5 text-accent-ink underline underline-offset-4 decoration-accent"
        href="https://wa.me/393421904804?text=Ciao%2C%20avrei%20una%20domanda%20sul%20mio%20problema%3A%20"
        target="_blank"
        rel="noopener"
      >
        <Icon name="whatsapp" size={16} /> Chiedici su WhatsApp: ti diciamo subito se possiamo aiutarti.
      </a>
    </p>
  </div>
</section>
