---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';

const title = 'Privacy · Studio Fisiatrico Russo';
const description =
  'Informativa privacy dello Studio Fisiatrico Russo: quali dati raccoglie il sito, come vengono usati e quali sono i tuoi diritti.';

const blocchi = [
  {
    t: 'Titolare del trattamento',
    p: 'Studio Fisiatrico Russo del Dott. Antonino Russo, Misterbianco (CT), P.IVA 06111760879 · antoninorusso994@gmail.com.',
  },
  {
    t: 'Quali dati e perché',
    p: 'Il modulo di contatto chiede solo nome, numero di telefono e una preferenza sull’orario di ricontatto, al solo scopo di richiamarti per fissare un appuntamento (base giuridica: consenso, art. 6.1.a GDPR). Il sito non chiede né raccoglie informazioni sulla tua salute.',
  },
  {
    t: 'Come viaggiano i dati',
    p: 'Questo sito non ha un server che memorizza dati: premendo “Invia” il messaggio viene composto e aperto nella tua app WhatsApp, e sei tu a inviarlo allo studio. Alla conversazione si applicano le condizioni del servizio WhatsApp (Meta). Ciò che scegli di scrivere in chat è una comunicazione diretta tra te e lo studio.',
  },
  {
    t: 'Cookie e tracciamento',
    p: 'Il sito non usa cookie né strumenti di tracciamento o profilazione: per questo non trovi banner. I caratteri tipografici sono ospitati su questo stesso sito, quindi la visita non genera richieste verso Google o altri fornitori. Durante la navigazione può essere usata una memorizzazione tecnica temporanea (sessione del browser), necessaria solo alle transizioni tra le pagine e cancellata automaticamente.',
  },
  {
    t: 'I tuoi diritti',
    p: 'Puoi chiedere in ogni momento accesso, rettifica o cancellazione dei tuoi dati scrivendo a antoninorusso994@gmail.com. Se ritieni che il trattamento violi la normativa, puoi proporre reclamo al Garante per la protezione dei dati personali (www.garanteprivacy.it).',
  },
];
---
<Base title={title} description={description}>
  <header class="nav">
    <div class="wrap flex items-center justify-between gap-6 h-[68px]">
      <a class="flex items-baseline gap-2 font-display font-semibold text-[1.14rem] text-ink whitespace-nowrap" href="/">
        Studio Fisiatrico Russo
        <span class="w-2 h-2 rounded-full bg-accent shrink-0 translate-y-[-2px]" aria-hidden="true"></span>
      </a>
      <a class="text-[0.92rem] font-semibold text-muted hover:text-accent-ink transition" href="/">← Torna al sito</a>
    </div>
  </header>
  <main id="main" class="section">
    <div class="wrap max-w-[52rem]">
      <span class="eyebrow">Privacy</span>
      <h1 class="h-display mt-3">Come trattiamo i tuoi dati.</h1>
      <p class="mt-4 text-muted">Ultimo aggiornamento: luglio 2026.</p>
      <div class="mt-9 flex flex-col gap-7">
        {blocchi.map((b) => (
          <div class="border-t border-line pt-6">
            <h2 class="font-display text-[1.25rem] font-semibold">{b.t}</h2>
            <p class="mt-2 text-[0.98rem] leading-[1.7] text-muted max-w-[65ch]">{b.p}</p>
          </div>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
